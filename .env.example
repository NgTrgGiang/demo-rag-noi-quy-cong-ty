# === Cấu hình biến môi trường ===
# Copy file này thành .env rồi điền key thật:  copy .env.example .env

# Chọn provider: openai | gemini | ollama  (mặc định openai)
PROVIDER=openai

# --- OpenAI (mặc định) ---
OPENAI_API_KEY=

# --- Google Gemini (nếu PROVIDER=gemini) ---
# GOOGLE_API_KEY=

# --- Ollama (nếu PROVIDER=ollama) ---
# Không cần key. Chỉ cần cài Ollama và chạy: ollama serve
